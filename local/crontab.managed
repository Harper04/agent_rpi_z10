# Sysadmin Agent — Managed Crontab
#
# SOURCE OF TRUTH for this machine's crontab.
# Apply with:  ./scripts/cron/install-crontab.sh
# Never edit crontab directly — edit this file and re-install.
#
# Changes are tracked in git, reviewable, and reversible.

SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin

# Daily 02:00 — btrfs snapshot + 30-day retention (no-op on non-btrfs systems)
0 2 * * *    /home/tomjaster/sysadmin-agent/scripts/cron/btrfs-snapshot.sh

# Daily 03:00 — Security updates only (unattended)
0 3 * * *    /home/tomjaster/sysadmin-agent/scripts/cron/cron-runner.sh "upgrade --security-only --unattended"

# Weekly Sunday 04:00 — Full system upgrade (unattended)
0 4 * * 0    /home/tomjaster/sysadmin-agent/scripts/cron/cron-runner.sh "upgrade --unattended"

# Weekly Monday 05:00 — Full inventory refresh
0 5 * * 1    /home/tomjaster/sysadmin-agent/scripts/cron/cron-runner.sh "inventory"

# Daily 06:00 — Health check
0 6 * * *    /home/tomjaster/sysadmin-agent/scripts/cron/cron-runner.sh "health"

# Every 6 hours — Auto-merge upstream if LLM deems it safe
30 */6 * * * /home/tomjaster/sysadmin-agent/scripts/cron/upstream-sync.sh

# Every 15 minutes — DNS IP update safety net (main trigger is networkd-dispatcher)
*/15 * * * * /home/tomjaster/sysadmin-agent/scripts/dns/dns-ip-update.sh >> /home/tomjaster/sysadmin-agent/local/logs/dns-ip-update.log 2>&1
