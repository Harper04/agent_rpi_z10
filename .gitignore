# ============================================================
# UPSTREAM TEMPLATE .gitignore
# ============================================================
# Git remotes:
#   upstream = shared template repo (agents, skills, scripts)
#   origin   = this machine's repo (includes local/)
# ============================================================

# --- Machine-specific data (NEVER in template repo — belongs in origin/machine repo only) ---
# local/ is Tier 3: machine-specific configs, docs, secrets. NEVER pushed upstream.
# Leading slash anchors to repo root so templates/local/ is NOT blocked.
/local/

# --- Secrets (NEVER committed anywhere) ---
local/.env
*.key
*.pem
*.p12
.git-credentials

# --- Runtime files (NEVER committed) ---
local/logs/
.claude/session-log.jsonl
.claude/changed-files.log
.claude/telegram-offset

# --- Backup files (created by backup-before-edit hook) ---
*.bak.*

# --- OS & Editor ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
