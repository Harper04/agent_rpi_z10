# ============================================================
# UPSTREAM TEMPLATE .gitignore
# ============================================================
# Git remotes:
#   upstream = shared template repo (agents, skills, scripts)
#   origin   = this machine's repo (includes local/)
# ============================================================

# --- Machine-specific data ---
# local/ is tracked in machine repos (origin) but NEVER pushed upstream.
# The upstream template .gitignore has "/local/" here — machine repos remove it.
# !local/ is implicit (line removed, not negated) so local/ IS tracked.

# --- Secrets (NEVER committed anywhere) ---
local/.env
*.key
*.pem
*.p12
.git-credentials

# --- Runtime files (NEVER committed) ---
local/logs/
.claude/session-log.jsonl
.claude/changed-files.log
.claude/telegram-offset

# --- Backup files (created by backup-before-edit hook) ---
*.bak.*

# --- OS & Editor ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
