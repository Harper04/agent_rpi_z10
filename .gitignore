# ============================================================
# .gitignore — shared by upstream template AND machine repos
# ============================================================
# This file is IDENTICAL in both repos. local/ is NOT ignored here.
# A pre-push hook prevents local/ from reaching upstream instead.
# See: scripts/hooks/pre-push-no-local-upstream.sh
# ============================================================

# --- Machine-specific data ---
# local/ is tracked normally. Secrets and runtime files below are excluded.
# Protection against leaking local/ to upstream is enforced at push time
# (pre-push hook + GitHub Actions CI), not via .gitignore.

# --- Secrets (NEVER committed anywhere) ---
local/.env
*.key
*.pem
*.p12
.git-credentials

# --- Runtime files (NEVER committed) ---
local/logs/
.claude/session-log.jsonl
.claude/changed-files.log
.claude/telegram-offset

# --- Backup files (created by backup-before-edit hook) ---
*.bak.*

# --- OS & Editor ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
