# Sysadmin Agent — Environment Configuration
# Copy to local/.env and fill in your values:
#   cp .env.example local/.env
#
# ⚠️  This file (local/.env) is gitignored and NEVER committed.

# === GitHub Access ===
# Fine-grained PAT for this machine.
# Create at: https://github.com/settings/personal-access-tokens/new
#
# Scoping (per machine):
#   - Resource owner:  your account
#   - Repository access: "Only select repositories"
#     → select: sysadmin-agent (template) + sysadmin-<machine> (this machine)
#   - Permissions → Repository:
#     → Contents: Read and write
#     → Metadata: Read-only (auto-granted)
#   - Expiration: 90 days (rotate via /rotate-token or manually)
#
# The token is used by the git credential helper (scripts/git/git-credential-local-env.sh)
# and NEVER appears in remote URLs or git config.
GITHUB_TOKEN=github_pat_XXXXXXXXXXXXXXXXXXXX

# === Telegram Bot ===
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here
# Your chat ID (send /start to bot, then check https://api.telegram.org/bot<TOKEN>/getUpdates)
TELEGRAM_CHAT_ID=your-chat-id-here

# === Optional ===
# Polling interval for Telegram bot in seconds (default: 5)
POLL_INTERVAL=5
# Claude model override (default: uses subscription default)
# CLAUDE_MODEL=sonnet

# === For Gitea/Forgejo (if not using GitHub) ===
# GITEA_TOKEN=your-gitea-token-here
