# Sysadmin Agent — Scheduled Tasks
# Install with: crontab scripts/cron/crontab.example
# Edit with:    crontab -e
#
# Paths use %REPO_PATH% placeholder — substituted by setup.sh

SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin

# Daily 03:00 — Security updates only (unattended)
0 3 * * *    %REPO_PATH%/scripts/cron/cron-runner.sh "upgrade --security-only --unattended"

# Weekly Sunday 04:00 — Full system upgrade (unattended)
0 4 * * 0    %REPO_PATH%/scripts/cron/cron-runner.sh "upgrade --unattended"

# Daily 06:00 — Health check
0 6 * * *    %REPO_PATH%/scripts/cron/cron-runner.sh "health-check"

# Weekly Monday 05:00 — Backup verification
0 5 * * 1    %REPO_PATH%/scripts/cron/cron-runner.sh "backup-verify"

# Monthly 1st 05:30 — Full inventory refresh
30 5 1 * *   %REPO_PATH%/scripts/cron/cron-runner.sh "inventory"

# Daily 02:00 — btrfs snapshot + 30-day retention (no-op on non-btrfs systems)
0 2 * * *    %REPO_PATH%/scripts/cron/btrfs-snapshot.sh
